      <column caption='From' datatype='spatial' name='[Calculation_0023123224518656]' role='measure' type='nominal'>
        <calculation class='tableau' formula='MAKEPOINT([Geometry Coordinates 1 1],[Geometry Coordinates 1 0])' />
      </column>
      <column caption='To' datatype='spatial' name='[Calculation_0023123224711169]' role='measure' type='nominal'>
        <calculation class='tableau' formula='MAKEPOINT([Geometry Coordinates 0 1],[Geometry Coordinates 0 0])' />
      </column>
      <column caption='Line' datatype='spatial' name='[Calculation_0023123225145346]' role='measure' type='nominal'>
        <calculation class='tableau' formula='MAKELINE([Calculation_0023123224518656],[Calculation_0023123224711169])' />
      </column>
      <column caption='Distance' datatype='real' name='[Calculation_0023123226128387]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DISTANCE([Calculation_0023123224518656],[Calculation_0023123224711169],&quot;km&quot;)' />
      </column>
      <column caption='Flight Count' datatype='string' name='[Calculation_0023123227971588]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Route - Split 1] = &quot;SFO&quot; THEN [Route - Split 2] ELSE [Route - Split 1] END' />
      </column>
      <column datatype='date' name='[Date]' role='dimension' type='ordinal' />
      <column caption='Route - Split 1' datatype='string' name='[Route - Split 1]' role='dimension' type='nominal' user:SplitFieldIndex='1' user:SplitFieldOrigin='[federated.1v7pira0s76yw719u8vb6109msqi].[Route]'>
        <calculation class='tableau' formula='TRIM( SPLIT( [Route], &quot;-&quot;, 1 ) )' />
      </column>
      <column caption='Route - Split 2' datatype='string' name='[Route - Split 2]' role='dimension' type='nominal' user:SplitFieldIndex='2' user:SplitFieldOrigin='[federated.1v7pira0s76yw719u8vb6109msqi].[Route]'>
